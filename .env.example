# =============================================================================
# ANDREI AI AGENT SYSTEM - Environment Variables
# Copy to .env and fill in your values. NEVER commit .env to git.
# =============================================================================

# --- Application ---
APP_ENV=development
LOG_LEVEL=INFO
TIMEZONE=Europe/Bucharest
USER_NAME=Andrei

# --- LLM: Grok (xAI) - Primary ---
XAI_API_KEY=your_xai_api_key_here
GROK_MODEL=grok-4.3

# --- LLM: Fallback Providers ---
OPENAI_API_KEY=your_openai_api_key_here
OPENAI_MODEL=gpt-4o
ANTHROPIC_API_KEY=your_anthropic_api_key_here
ANTHROPIC_MODEL=claude-3-5-sonnet-20241022
LLM_FALLBACK_ORDER=grok,anthropic,openai

# --- Notion API ---
NOTION_API_KEY=secret_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
NOTION_FAMILY_DB_ID=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
NOTION_IDEAS_DB_ID=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
NOTION_CONTENT_CREATION_ID=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
NOTION_POSTING_PLAN_DB_ID=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
NOTION_AJUT_CUM_POT_DB_ID=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
NOTION_JOB_DB_ID=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
NOTION_BRIEFINGS_PAGE_ID=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# --- Google APIs (OAuth2 or Service Account) ---
GOOGLE_CREDENTIALS_JSON={"type":"service_account",...}
GOOGLE_CALENDAR_ID=primary
GOOGLE_DRIVE_FOLDER_ID=your_folder_id
# Google Sheets — share each sheet with service account email (Editor access)
# Run: python scripts/setup_google_sheets.py to create them automatically
GOOGLE_SHEET_AJUT_CUM_POT_ID=your_ajut_sheet_id
GOOGLE_SHEET_AJUT_TAB=Ajut Cum Pot
GOOGLE_SHEET_EDITOR_PIPELINE_ID=your_editor_sheet_id
GOOGLE_SHEET_EDITOR_TAB=Content Creation

# --- Notifier: telegram | whatsapp | discord ---
NOTIFIER_PROVIDER=telegram

# --- Telegram Bot (dacă NOTIFIER_PROVIDER=telegram) ---
TELEGRAM_BOT_TOKEN=123456789:ABCdefGHIjklMNOpqrsTUVwxyz
TELEGRAM_CHAT_ID=123456789

# --- WhatsApp Business Cloud API (dacă NOTIFIER_PROVIDER=whatsapp) ---
# Setup: developers.facebook.com → App → WhatsApp → API Setup
WHATSAPP_ACCESS_TOKEN=your_permanent_or_temporary_token
WHATSAPP_PHONE_NUMBER_ID=123456789012345
WHATSAPP_RECIPIENT=40722123456
WHATSAPP_API_VERSION=v21.0
WHATSAPP_TEMPLATE_LANGUAGE=ro
# Template-uri opționale (pentru mesaje în afara ferestrei 24h)
WHATSAPP_TEMPLATE_DAILY=daily_briefing
WHATSAPP_TEMPLATE_WEEKLY=weekly_review
WHATSAPP_TEMPLATE_GENERAL=agent_notification

# --- Discord Webhook (dacă NOTIFIER_PROVIDER=discord) ---
# Server Settings → Integrations → Webhooks → New Webhook → Copy URL
DISCORD_WEBHOOK_URL=https://discord.com/api/webhooks/123456789/abcdefghijklmnop
DISCORD_WEBHOOK_USERNAME=Andrei AI

# --- Discord Bot (chat interactiv, întrebări + update Notion) ---
# Developer Portal → Applications → New → Bot → Token
# Bot → Privileged Gateway Intents → MESSAGE CONTENT INTENT = ON
# OAuth2 → URL Generator → scopes: bot → permissions: Send Messages, Read Message History
ENABLE_DISCORD_BOT=false
DISCORD_BOT_TOKEN=your_discord_bot_token
# Right-click channel → Copy Channel ID (Developer Mode ON in Discord settings)
DISCORD_ALLOWED_CHANNEL_IDS=123456789012345678
# Optional: restrict to your user ID only (right-click your name → Copy User ID)
DISCORD_ALLOWED_USER_IDS=

# Mesaje vocale Discord (transcriere OpenAI Whisper — necesită OPENAI_API_KEY)
ENABLE_DISCORD_VOICE=true
DISCORD_VOICE_LANGUAGE=ro
DISCORD_VOICE_MODEL=whisper-1
DISCORD_VOICE_MAX_DURATION_SECONDS=120

# Mod research (Grok/ChatGPT-style: research: / grok: + research web automat)
ENABLE_RESEARCH_MODE=true

# --- Web search (doar la cerere explicită: caută: / caută pe net) ---
ENABLE_WEB_SEARCH=true
WEB_SEARCH_MAX_RESULTS=5
WEB_SEARCH_FETCH_PAGES=true
WEB_SEARCH_MAX_PAGES_TO_READ=3
WEB_SEARCH_PAGE_CHAR_LIMIT=3500
WEB_SEARCH_FETCH_TIMEOUT_SECONDS=15

# --- Memory: Supabase (recommended) ---
SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co
SUPABASE_KEY=your_supabase_anon_or_service_key
SUPABASE_SERVICE_KEY=your_supabase_service_role_key

# --- Memory: Pinecone (alternative) ---
PINECONE_API_KEY=your_pinecone_api_key
PINECONE_INDEX_NAME=andreia-memory
PINECONE_ENVIRONMENT=us-east-1

# Memory provider: supabase | pinecone
MEMORY_PROVIDER=supabase

# --- Railway / Production ---
PORT=8000
RAILWAY_ENVIRONMENT=production

# --- Scheduler ---
DAILY_BRIEFING_HOUR=7
DAILY_BRIEFING_MINUTE=0
WEEKLY_REVIEW_DAY=sunday
WEEKLY_REVIEW_HOUR=20
ENABLE_SCHEDULER=true
# Reminder automat la 2h — verifică taskuri deschise în Notion
ENABLE_TASK_REMINDER=true
TASK_REMINDER_INTERVAL_HOURS=2
TASK_REMINDER_START_HOUR=8
TASK_REMINDER_END_HOUR=18
TASK_REMINDER_DAYS=mon,tue,wed,thu,fri,sat
# Trimite în canalul Discord Bot (dacă botul rulează); altfel folosește NOTIFIER_PROVIDER
TASK_REMINDER_DISCORD=true
# Reminder în DM (privat) — ID Discord (right-click user → Copy User ID)
TASK_REMINDER_DISCORD_DM=true
TASK_REMINDER_DISCORD_DM_USER_IDS=1517419904360382486